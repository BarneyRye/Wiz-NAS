{
  "name": "wiz-nas-backend",
  "version": "1.0.0",
  "description": "Backend API for Wiz-NAS",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "module": "src/server.ts",
  "scripts": {
    "dev": "bun --hot --env-file=../.env src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/jsonwebtoken": "^9.0.6",
    "bun-types": "latest",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
